---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteUrl = "https://estratario.com";
const locale = "es" as const;
---

<BaseLayout
	locale={locale}
	title="Página no encontrada — Estratario"
	description="La página que buscas no existe o ha sido movida. Regresa al inicio de Estratario para descubrir cómo centralizar tu estrategia de marketing con IA."
	canonical={`${siteUrl}/404/`}
>
	<div class="px-4 md:px-8 max-w-prose mx-auto pt-24 pb-24 text-center">
		<h1 class="text-6xl font-extrabold mb-4 text-primary">404</h1>
		<h2 class="text-2xl font-bold mb-4 text-foreground-heading">Página no encontrada</h2>
		<p class="text-foreground-secondary mb-10 max-w-md mx-auto">
			La página que buscas no existe o ha sido movida. Pero no te preocupes, el Core Estratégico sigue intacto.
		</p>
		<a
			href="/"
			class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white font-bold bg-btn-gradient shadow-btn no-underline transition-transform hover:-translate-y-0.5"
		>
			Volver al inicio
		</a>
	</div>
</BaseLayout>
