---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const locale = "es" as const;
const allPosts = (await getCollection("blog")) as CollectionEntry<"blog">[];
const posts = allPosts
	.filter((post) => post.data.locale === locale && !post.data.draft)
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout locale={locale} title="Blog — Estratario" description="Blog">
	<div class="px-4 md:px-8 max-w-prose mx-auto pt-24 pb-24">
		<h1 class="text-3xl font-bold mb-8 text-foreground-heading">Blog</h1>
		{posts.length === 0 ? (
			<p class="text-foreground-secondary">Coming soon.</p>
		) : (
			<ul class="space-y-8">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.slug}`} class="block no-underline p-6 rounded-xl bg-card border border-card transition-shadow hover:shadow-card">
							<h2 class="text-xl font-bold mb-2 text-foreground">{post.data.title}</h2>
							<p class="text-sm text-foreground-secondary">{post.data.description}</p>
							<time class="text-2xs text-foreground-tertiary">{post.data.pubDate.toLocaleDateString()}</time>
						</a>
					</li>
				))}
			</ul>
		)}
	</div>
</BaseLayout>
