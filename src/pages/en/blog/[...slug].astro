---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import type { Locale } from "../../../config";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
	const blogEntries = (await getCollection("blog")) as CollectionEntry<"blog">[];
	const enEntries = blogEntries.filter(
		(entry) => !entry.data.draft && entry.data.locale === "en",
	);
	return enEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const siteUrl = "https://estratario.com";
const canonical = `${siteUrl}/en/blog/${entry.slug}`;
const description = entry.data.description;

// Map EN slug to ES slug for hreflang
const esSlug = entry.slug === "strategic-core-guide" ? "guia-core-estrategico" : entry.slug;
const alternates = [
	{ lang: "es", url: `${siteUrl}/blog/${esSlug}` },
];

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	headline: entry.data.title,
	description,
	datePublished: entry.data.pubDate.toISOString(),
	inLanguage: "en",
	author: {
		"@type": "Person",
		name: "César Cuitiño",
		url: "https://cesarcuitino.cl",
	},
	publisher: {
		"@type": "Organization",
		name: "Estratario",
		logo: {
			"@type": "ImageObject",
			url: `${siteUrl}/icon.svg`,
		},
	},
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonical,
	},
};
---

<BaseLayout
	locale={entry.data.locale as Locale}
	title={`${entry.data.title} — Estratario`}
	description={description}
	canonical={canonical}
	ogType="article"
	alternates={alternates}
	jsonLd={articleSchema}
>
	<article class="px-4 md:px-8 max-w-prose mx-auto pt-24 pb-24 prose prose-lg dark:prose-invert">
		<time class="text-sm text-foreground-tertiary">{entry.data.pubDate.toLocaleDateString()}</time>
		<h1 class="text-3xl font-bold mt-2 mb-8 text-foreground-heading">{entry.data.title}</h1>
		<Content />
	</article>
</BaseLayout>

<style>
	.prose {
		--tw-prose-body: var(--text);
		--tw-prose-headings: var(--text-heading);
		--tw-prose-links: var(--primary);
		--tw-prose-bold: var(--text);
		--tw-prose-quotes: var(--text-secondary);
		--tw-prose-quote-borders: var(--primary);
		--tw-prose-code: var(--text);
		--tw-prose-pre-bg: var(--surface);
		--tw-prose-pre-code: var(--text);
		--tw-prose-th-borders: var(--border);
		--tw-prose-td-borders: var(--border-secondary);
		--tw-prose-hr: var(--border-secondary);
		--tw-prose-bullets: var(--border-secondary);
	}
</style>
