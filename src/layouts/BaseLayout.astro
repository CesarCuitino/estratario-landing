---
import type { Locale } from "../config";
import "../styles/globals.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Alternate {
	lang: string;
	url: string;
}

interface Props {
	locale: Locale;
	title?: string;
	description?: string;
	canonical?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	alternates?: Alternate[];
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	locale,
	title = "Estratario",
	description = "",
	canonical = "",
	ogImage = "/og-image.png",
	ogType = "website",
	alternates = [],
	jsonLd,
} = Astro.props;

const siteUrl = "https://estratario.com";
const defaultOgImage = `${siteUrl}${ogImage}`;
const pageTitle = title.includes("—") ? title : `${title} — Estratario`;
---

<!doctype html>
<html data-theme="light" lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light dark" />

		<!-- Icon -->
		<link rel="icon" type="image/svg+xml" href="/icon.svg" />
		<meta name="theme-color" content="#f0edff" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,300;1,9..40,400;1,9..40,500;1,9..40,600;1,9..40,700;1,9..40,800&family=Space+Mono:wght@400;700&display=swap" media="print" onload="this.media='all'" />

		<!-- SEO: Title & Description -->
		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		<!-- SEO: Canonical -->
		{canonical && <link rel="canonical" href={canonical} />}

		<!-- SEO: Hreflang -->
		{alternates.map((alt) => (
			<link rel="alternate" hreflang={alt.lang} href={alt.url} />
		))}
		<link rel="alternate" hreflang={locale} href={canonical || siteUrl} />
		<link rel="alternate" hreflang="x-default" href={siteUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={pageTitle} />
		{description && <meta property="og:description" content={description} />}
		<meta property="og:url" content={canonical || siteUrl} />
		<meta property="og:site_name" content="Estratario" />
		<meta property="og:locale" content={locale === "es" ? "es_CL" : "en_US"} />
		<meta property="og:image" content={defaultOgImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Cards -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		{description && <meta name="twitter:description" content={description} />}
		<meta name="twitter:image" content={defaultOgImage} />

		<!-- JSON-LD Schema -->
		{jsonLd && (
			<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		)}

		<!-- Theme & locale boot -->
		<script is:inline>
			(() => {
				// --- Theme ---
				const fallbackTheme = window.matchMedia?.(
					"(prefers-color-scheme: dark)",
				).matches
					? "dark"
					: "light";
				let storedTheme = null;
				try {
					const raw = localStorage.getItem("theme");
					const candidate = raw && JSON.parse(raw)?.state?.theme;
					if (candidate === "dark" || candidate === "light")
						storedTheme = candidate;
				} catch (_) {}
				const theme = storedTheme ?? fallbackTheme;
				const root = document.documentElement;
				const metaTheme = document.querySelector('meta[name="theme-color"]');
				root.setAttribute("data-theme", theme);
				const themes = {
					dark: {
						bg: "linear-gradient(135deg, #0f0c29, #302b63, #24243e)",
						fg: "#ffffff",
						muted: "rgba(255,255,255,0.16)",
						meta: "#1a1640",
					},
					light: {
						bg: "linear-gradient(135deg, #e8e4ff, #f0edff, #ede8ff)",
						fg: "#1a1433",
						muted: "rgba(80,60,160,0.18)",
						meta: "#f0edff",
					},
				};
				const t = themes[theme];
				root.style.setProperty("--page-bg", t.bg);
				root.style.setProperty("--text", t.fg);
				root.style.setProperty("--border", t.muted);
				metaTheme?.setAttribute("content", t.meta);

				// --- Locale redirect (only on root /) ---
				if (location.pathname === "/" || location.pathname === "/index.html") {
					let savedLocale = null;
					try { savedLocale = localStorage.getItem("locale"); } catch (_) {}
					if (savedLocale === "en") {
						location.replace("/en/");
					} else if (!savedLocale) {
						const lang = navigator.language || navigator.userLanguage || "";
						if (lang.startsWith("en")) {
							location.replace("/en/");
						}
					}
				}
			})();
		</script>
	</head>
	<body class="app-mounted">
		<a href="#main" class="skip-link">Skip to content</a>
		<Header locale={locale} />
		<main id="main" tabindex="-1">
			<slot />
		</main>
		<Footer locale={locale} />
		<script is:inline>
			(() => {
				function r(s) {
					return s.replace(/[a-zA-Z]/g, c => String.fromCharCode(c.charCodeAt(0) + (c.toLowerCase() < "n" ? 13 : -13)));
				}
				document.querySelectorAll("[data-rot13-href]").forEach(el => {
					if (el instanceof HTMLAnchorElement) el.href = "mailto:" + r(el.getAttribute("data-rot13-href") || "");
				});
				document.querySelectorAll("[data-rot13]").forEach(el => {
					el.textContent = r(el.getAttribute("data-rot13") || "");
				});
			})();
		</script>
	</body>
</html>
