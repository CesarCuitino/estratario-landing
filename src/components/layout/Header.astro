---
import type { Locale } from "../../config";
import AppLogo from "../ui/AppLogo.astro";
import { APP_URL } from "../../config";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = (await import("../../i18n/t")).t;
const langHref = locale === "es" ? "/en/" : "/";
const langLabel = locale === "es" ? "EN" : "ES";
---

<header
	class="fixed top-0 left-0 right-0 z-50 border-b border-border-secondary backdrop-blur"
	style="background: color-mix(in srgb, var(--page-bg-solid) 80%, transparent);"
>
	<div class="flex items-center justify-between h-14 px-4 md:px-8 max-w-container mx-auto">
		<a href={locale === "es" ? "/" : `/${locale}/`} class="flex items-center gap-2 no-underline" aria-label="Estratario — Home">
			<AppLogo />
		</a>

		<nav class="flex items-center gap-2 md:gap-3" aria-label={t("landing.nav.lang_label", locale)}>
			<button
				id="theme-toggle"
				type="button"
				class="w-9 h-9 flex items-center justify-center rounded-lg cursor-pointer bg-surface text-foreground border border-border-secondary text-base transition-colors hover:bg-surface-hover"
				aria-label={t("landing.nav.theme_toggle", locale)}
				aria-pressed="false"
			>
				<svg class="theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="5" />
					<line x1="12" y1="1" x2="12" y2="3" />
					<line x1="12" y1="21" x2="12" y2="23" />
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
					<line x1="1" y1="12" x2="3" y2="12" />
					<line x1="21" y1="12" x2="23" y2="12" />
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
				</svg>
				<svg class="theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
				</svg>
			</button>

			<a
				href={langHref}
				class="text-2xs font-semibold uppercase tracking-widest no-underline text-foreground-secondary hover:text-foreground transition-colors px-1"
				aria-label={t("landing.nav.lang_label", locale)}
				lang={locale === "es" ? "en" : "es"}
			>
				{langLabel}
			</a>

			<a
				href={`${APP_URL}/login`}
				class="text-xs font-semibold no-underline px-3 py-1.5 rounded-lg transition-colors text-foreground-secondary border border-border-secondary hover:bg-surface-hover"
			>
				{t("landing.nav.login", locale)}
			</a>

			<a
				href={`${APP_URL}/register`}
				class="text-xs font-bold no-underline px-4 py-1.5 rounded-xl text-white bg-btn-gradient shadow-btn transition-transform hover:-translate-y-0.5"
			>
				{t("landing.nav.cta_desktop", locale)}
			</a>
		</nav>
	</div>
</header>

<style>
	.theme-icon-moon { display: none; }
	[data-theme="dark"] .theme-icon-sun { display: none; }
	[data-theme="dark"] .theme-icon-moon { display: block; }
</style>

<script is:inline>
	const toggle = document.getElementById("theme-toggle");
	const themes = {
		dark: {
			bg: "linear-gradient(135deg, #0f0c29, #302b63, #24243e)",
			fg: "#ffffff",
			muted: "rgba(255,255,255,0.16)",
			meta: "#1a1640",
		},
		light: {
			bg: "linear-gradient(135deg, #e8e4ff, #f0edff, #ede8ff)",
			fg: "#1a1433",
			muted: "rgba(80,60,160,0.18)",
			meta: "#f0edff",
		},
	};
	toggle?.addEventListener("click", () => {
		const root = document.documentElement;
		const current = root.getAttribute("data-theme");
		const next = current === "dark" ? "light" : "dark";
		root.setAttribute("data-theme", next);
		localStorage.setItem("theme", JSON.stringify({ state: { theme: next } }));
		toggle?.setAttribute("aria-pressed", String(next === "dark"));
		const t = themes[next];
		root.style.setProperty("--page-bg", t.bg);
		root.style.setProperty("--text", t.fg);
		root.style.setProperty("--border", t.muted);
		const metaTheme = document.querySelector('meta[name="theme-color"]');
		if (metaTheme) {
			metaTheme.setAttribute("content", t.meta);
		}
	});
	const initTheme = document.documentElement.getAttribute("data-theme");
	toggle?.setAttribute("aria-pressed", String(initTheme === "dark"));
</script>
