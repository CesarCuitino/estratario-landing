---
interface Props {
	href?: string;
}

const { href = "" } = Astro.props;
---

<a href={href} class="gradient-btn">
	<slot />
</a>

<style>
	.gradient-btn {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 7px;
		padding: 11px 24px;
		border-radius: 12px;
		color: #fff;
		font-size: 14px;
		font-weight: 700;
		font-family: "DM Sans", system-ui, sans-serif;
		border: 0;
		cursor: pointer;
		text-decoration: none;
		min-width: 142px;
		background: var(--btn-gradient);
		box-shadow: var(--btn-shadow);
		overflow: hidden;
		isolation: isolate;
		transform: translateY(0);
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.gradient-btn::after {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: 12px;
		background: var(--btn-hover-gradient);
		opacity: 0;
		transition: opacity 0.35s;
		z-index: -1;
	}

	.gradient-btn:hover {
		transform: translateY(-2px);
	}
	.gradient-btn:hover::after {
		opacity: 1;
	}

	.gradient-btn:focus-visible {
		outline: 2px solid var(--primary);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.gradient-btn,
		.gradient-btn::after {
			transition: none;
		}
		.gradient-btn:hover {
			transform: none;
		}
	}
</style>
