---
import Trans from "../Trans.astro";
import type { Locale } from "../../config";

interface Props {
	locale: Locale;
	type: "danger" | "success";
	label: string;
	description: string;
}

const { locale, type, label, description } = Astro.props;
const isSuccess = type === "success";
const icon = isSuccess
	? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
	: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
---

<div
	class:list={[
		"flex items-start gap-3.5 p-4 rounded-xl mt-auto backdrop-blur",
		isSuccess ? "text-success border-success" : "text-danger border-danger",
	]}
	style={
		isSuccess
			? "background:linear-gradient(135deg, var(--success-soft) 0%, var(--primary-soft) 100%); border-width:1px; border-style:solid; border-color:color-mix(in srgb, var(--success) 25%, transparent);"
			: "background:linear-gradient(135deg, rgba(239,68,68,0.08) 0%, rgba(239,68,68,0.04) 100%); border-width:1px; border-style:solid; border-color:color-mix(in srgb, var(--danger) 20%, transparent);"
	}
>
	<span set:html={icon} class="shrink-0 mt-0.5" />
	<div class="flex flex-col gap-0.5">
		<span class:list={["font-bold text-2xs uppercase tracking-wider", isSuccess ? "text-success" : "text-danger"]}>
			{label}
		</span>
		<span class="text-sm text-foreground" style="opacity:0.9;">
			<Trans key={description} locale={locale} />
		</span>
	</div>
</div>
