---
import Trans from "../Trans.astro";
import StatusBanner from "../ui/StatusBanner.astro";
import type { Locale } from "../../config";
import { t } from "../../i18n/t";

interface Step {
	titleKey: string;
	descKey: string;
	iconFn: () => string;
}

interface Props {
	locale: Locale;
	steps: Step[];
	labelKey: string;
	statusKey: string;
	resultLabelKey: string;
	resultKey: string;
	variant: "danger" | "premium";
	badge?: string;
}

const { locale, steps, labelKey, statusKey, resultLabelKey, resultKey, variant, badge } = Astro.props;
const isPremium = variant === "premium";
---

<div
	class="flex-1 relative rounded-card flex flex-col border"
	class:list={[isPremium ? "bg-card border-card" : "border-danger/20"]}
	style={isPremium
		? "padding:clamp(1.5rem, 3vw, 2.25rem) clamp(2rem, 4vw, 3.5rem); max-width:680px; box-shadow:var(--card-shadow); backdrop-filter:var(--backdrop-blur); background:var(--card-bg);"
		: "padding:clamp(1.5rem, 3vw, 2.25rem) clamp(2rem, 4vw, 3.5rem); max-width:680px; box-shadow:0 8px 24px rgba(239,68,68,0.06); background:linear-gradient(135deg, rgba(239,68,68,0.06) 0%, rgba(239,68,68,0.03) 100%);"
	}
>
	{badge && (
		<div class="absolute top-5 right-5 px-2.5 py-0.5 rounded-full text-2xs font-bold tracking-wider text-white bg-brand-gradient">
			{badge}
		</div>
	)}

	<div class="mb-6">
		<p class:list={["text-2xs font-semibold tracking-widest uppercase mb-1.5", isPremium ? "text-primary" : "text-foreground-tertiary"]}>
			{t(labelKey, locale)}
		</p>
		<h4 class:list={["text-lg font-bold m-0", isPremium ? "text-foreground" : "text-danger"]}>
			{t(statusKey, locale)}
		</h4>
	</div>

	<div class="relative flex flex-col gap-7 pl-2 flex-1">
		<div
			class="absolute left-[21px] top-6 bottom-6 w-[2px]"
			style={isPremium ? "background:linear-gradient(to bottom, var(--primary), var(--success));" : "background:linear-gradient(to bottom, rgba(239,68,68,0.35), rgba(239,68,68,0.15));"}
			aria-hidden="true"
		/>

		{steps.map((step) => (
			<div class="relative z-[2] flex gap-4 items-start">
				<div
					class="w-7 h-7 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
					set:html={step.iconFn()}
					style={isPremium
						? "background:var(--brand-gradient); color:#fff; box-shadow:0 4px 12px color-mix(in srgb, var(--primary) 30%, transparent);"
						: "background:linear-gradient(135deg, #dc2626, #b91c1c); color:#fff; box-shadow:0 2px 8px rgba(220,38,38,0.35);"
					}
				/>

				<div class="flex flex-col gap-1.5">
					<span class="font-semibold text-[0.9375rem] text-foreground">{t(step.titleKey, locale)}</span>
					<p class="text-sm text-foreground-secondary leading-relaxed" style="line-height:1.65;">
						<Trans key={step.descKey} locale={locale} />
					</p>
				</div>
			</div>
		))}
	</div>

	<div class="pt-10">
		<StatusBanner
			locale={locale}
			type={isPremium ? "success" : "danger"}
			label={t(resultLabelKey, locale)}
			description={resultKey}
		/>
	</div>
</div>
