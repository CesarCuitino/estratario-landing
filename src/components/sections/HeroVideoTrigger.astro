---
import Trans from "../Trans.astro";
import type { Locale } from "../../config";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = (await import("../../i18n/t")).t;
---

<div class="flex-1 w-full relative flex items-center justify-center" style="transition:all 0.8s cubic-bezier(0.16, 1, 0.3, 1);">
	<button
		type="button"
		id="video-trigger"
		class="w-full max-w-[420px] aspect-[16/10] rounded-xl overflow-hidden cursor-pointer relative transition-all duration-300 border border-border-secondary bg-surface focus-visible:outline-2 focus-visible:outline-offset-2"
		aria-label={t("landing.hero.video_open", locale)}
	>
		<div class="absolute inset-0 opacity-[0.06] pointer-events-none" aria-hidden="true" style="background-image:radial-gradient(circle at 25% 25%, var(--primary) 1px, transparent 1px), radial-gradient(circle at 75% 75%, var(--primary) 1px, transparent 1px); background-size:24px 24px;"></div>
		<div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background:radial-gradient(circle at 50% 50%, var(--primary-soft) 0%, transparent 70%);"></div>

		<div class="absolute inset-0 p-3 flex flex-col items-center justify-center gap-3">
			<div class="w-16 h-16 rounded-full flex items-center justify-center transition-transform bg-primary" style="box-shadow:0 8px 30px color-mix(in srgb, var(--primary) 33%, transparent);">
				<svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<circle cx="12" cy="12" r="10" />
					<polygon points="10 8 16 12 10 16 10 8" fill="#fff" />
				</svg>
			</div>
			<span class="text-xs font-semibold text-center text-foreground-secondary">
				<Trans key="landing.hero.video_trigger" locale={locale} />
			</span>
		</div>

		<div class="absolute bottom-3.5 right-3.5 px-2.5 py-1 rounded-lg text-2xs font-semibold text-white font-mono" style="background:rgba(0,0,0,0.55); backdrop-filter:blur(8px);">
			3:00
		</div>
	</button>
</div>

<dialog
	id="video-modal"
	class="fixed inset-0 z-[100] bg-transparent p-0 m-auto max-w-[800px] w-[90vw] rounded-2xl overflow-hidden backdrop:bg-black/60"
	style="border:none;"
	aria-labelledby="video-modal-title"
>
	<div class="relative aspect-video bg-black">
		<h2 id="video-modal-title" class="sr-only">{t("landing.hero.video_title", locale)}</h2>
		<iframe
			id="video-frame"
			src=""
			title={t("landing.hero.video_title", locale)}
			class="w-full h-full border-none"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
			allowfullscreen
		></iframe>
		<button
			type="button"
			id="video-close"
			class="absolute top-3 right-3 w-9 h-9 rounded-full flex items-center justify-center text-white cursor-pointer transition-colors"
			style="background:rgba(0,0,0,0.6); backdrop-filter:blur(8px);"
			aria-label={t("landing.hero.video_close", locale)}
		>
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<line x1="18" y1="6" x2="6" y2="18" />
				<line x1="6" y1="6" x2="18" y2="18" />
			</svg>
		</button>
	</div>
</dialog>

<script is:inline>
	(() => {
		const trigger = document.getElementById("video-trigger");
		const modal = document.getElementById("video-modal");
		const frame = document.getElementById("video-frame");
		const closeBtn = document.getElementById("video-close");
		const VIDEO_ID = "dQw4w9WgXcQ";

		function openModal() {
			if (modal instanceof HTMLDialogElement && frame instanceof HTMLIFrameElement) {
				frame.src = "https://www.youtube.com/embed/" + VIDEO_ID + "?autoplay=1";
				modal.showModal();
			}
		}

		function closeModal() {
			if (modal instanceof HTMLDialogElement) {
				modal.close();
			}
			if (frame instanceof HTMLIFrameElement) {
				frame.src = "";
			}
		}

		trigger?.addEventListener("click", openModal);
		closeBtn?.addEventListener("click", closeModal);
		modal?.addEventListener("click", (e) => {
			if (e.target === modal) closeModal();
		});
		modal?.addEventListener("close", () => {
			if (frame instanceof HTMLIFrameElement) frame.src = "";
		});
	})();
</script>
